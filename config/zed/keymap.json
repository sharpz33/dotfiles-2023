// Zed keymap — kickstart.nvim parity (leader = space)
//
// Docs: https://zed.dev/docs/key-bindings · default: command palette → "open default keymap"
// Vim contexts: VimControl, vim_mode == normal/visual/insert/operator/replace
// Source: ~/.config/nvim/init.lua + custom/plugins/

[
  // === GLOBAL: window navigation (C-h/j/k/l) ===
  {
    "context": "Editor && VimControl && !menu",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },

  // === INSERT MODE: jk → escape ===
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "k j": "vim::NormalBefore"
    }
  },

  // === NORMAL/VISUAL MODE: leader-key shortcuts (space-prefix) ===
  {
    "context": "VimControl && !menu",
    "bindings": {
      // <Esc> clear search highlight (kickstart line 164)
      "escape": ["workspace::SendKeystrokes", "escape : nohlsearch enter"],

      // === Telescope-style search (<leader>s*) ===
      "space s f": "file_finder::Toggle",
      "space s g": "pane::DeploySearch",
      "space s w": "pane::DeploySearch",
      "space s d": "diagnostics::Deploy",
      "space s .": "projects::OpenRecent",
      "space s h": "command_palette::Toggle",
      "space s k": "command_palette::Toggle",
      "space s s": "command_palette::Toggle",
      "space space": "tab_switcher::Toggle",
      "space /": "buffer_search::Deploy",

      // === LSP (<leader>r/c/D/d/w/q + g*) ===
      "space r n": "editor::Rename",
      "space c a": "editor::ToggleCodeActions",
      "space f": "editor::Format",
      "space q": "diagnostics::Deploy",
      "space D": "editor::GoToTypeDefinition",
      "space d s": "outline::Toggle",
      "space w s": "project_symbols::Toggle",

      // === Goto (g*) ===
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDeclaration",
      "g r": "editor::FindAllReferences",
      "g I": "editor::GoToImplementation",

      // === Panele ===
      "space e": "workspace::ToggleLeftDock",
      "space o": "outline_panel::ToggleFocus",
      "space t": "terminal_panel::ToggleFocus",

      // === Agent panel (Claude Agent + Codex) ===
      "space a": "agent::ToggleFocus",
      "space a n": ["agent::NewExternalAgentThread", { "agent": { "custom": { "name": "claude-acp" } } }],
      "space a c": ["agent::NewExternalAgentThread", { "agent": { "custom": { "name": "codex-acp" } } }]
    }
  },

  // === EmptyPane: skróty bez otwartego pliku ===
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space s f": "file_finder::Toggle",
      "space space": "tab_switcher::Toggle",
      "space e": "workspace::ToggleLeftDock"
    }
  },

  // === Markdown: preview w obecnym tabie (Cmd-Shift-V) + preview na bok (Cmd-Shift-M) ===
  {
    "context": "Editor && extension == md",
    "bindings": {
      "cmd-shift-v": "markdown::OpenPreview",
      "cmd-shift-m": "markdown::OpenPreviewToTheSide",
      "space m p": "markdown::OpenPreviewToTheSide",
      "space m v": "markdown::OpenPreview"
    }
  },

  // === MarkdownPreview: nawigacja, search, close ===
  // Preview to read-only view, własne bindy (vim Editor/VimControl tu nie matchuje)
  {
    "context": "MarkdownPreview",
    "bindings": {
      // Close
      "q": "pane::CloseActiveItem",
      "cmd-w": "pane::CloseActiveItem",
      // Toggle przez Cmd-Shift-V → wraca do edytora (zamyka preview)
      "cmd-shift-v": "pane::CloseActiveItem",

      // Search w preview
      "/": "buffer_search::Deploy",
      "cmd-f": "buffer_search::Deploy",
      "n": "search::SelectNextMatch",
      "shift-n": "search::SelectPrevMatch",

      // Scroll vim-style
      "j": "editor::LineDown",
      "k": "editor::LineUp",
      "g g": "editor::MoveToBeginning",
      "shift-g": "editor::MoveToEnd",
      "ctrl-d": "editor::PageDown",
      "ctrl-u": "editor::PageUp",
      "pagedown": "editor::PageDown",
      "pageup": "editor::PageUp",
      "shift-j": "editor::PageDown",
      "shift-k": "editor::PageUp",

      // Pane navigation (spójne z resztą)
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp"
    }
  },

  // === Workspace-level: agent shortcut + base VSCode keymap (cmd-p/cmd-shift-p/cmd-`) ===
  {
    "context": "Workspace",
    "bindings": {
      "cmd-alt-c": ["agent::NewExternalAgentThread", { "agent": { "custom": { "name": "claude-acp" } } }]
    }
  },
  {
    "bindings": {
      "ctrl-alt-cmd-shift-right": [
        "workspace::MoveItemToPaneInDirection",
        {
          "direction": "right"
        }
      ]
    }
  }
]
